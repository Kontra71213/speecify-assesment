{
  "extends": "../../tooling/typescript/tsconfig.react.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "types": ["vite/client"],
    "noUncheckedSideEffectImports": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}